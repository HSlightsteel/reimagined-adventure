{
  "name": "@yoganataa/tstok",
  "version": "2.1.0",
  "description": "TypeScript-first TikTok Live Recorder library",
  "license": "MIT",
  "author": "Yoganataa",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "googleapis": "^171.4.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "telegram": "^2.26.22",
    "undici": "^6.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
